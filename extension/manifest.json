{
  "manifest_version": 3,
  "name": "Codex Web Assistant",
  "description": "Use local Codex to summarize, translate, and analyze the current web page.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Codex Web Assistant"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*"
  ]
}
